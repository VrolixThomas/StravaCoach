# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase project (https://supabase.com/dashboard/project/<id>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Postgres connection
# Use the POOLER URL on port 6543 (PgBouncer transaction mode) for serverless.
# Get from: Supabase dashboard → Database → Connection string → "Transaction" mode
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-DB-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# For Drizzle migrations, use the DIRECT connection (port 5432, not pooled)
DATABASE_URL_DIRECT=postgresql://postgres.YOUR-PROJECT:YOUR-DB-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Strava API (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=238752
STRAVA_CLIENT_SECRET=YOUR-SECRET
STRAVA_VERIFY_TOKEN=any-random-string-for-webhook-verification

# Vercel-only: set in Vercel dashboard env vars, not committed
# CRON_SECRET=any-random-string-to-protect-cron-endpoint
