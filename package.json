{
  "name": "strava-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "coach:brief": "bun run src/scripts/brief.ts",
    "coach:checkin": "bun run src/scripts/checkin.ts",
    "coach:adjust": "bun run src/scripts/adjust.ts",
    "coach:sync": "bun run src/scripts/sync.ts",
    "coach:seed": "bun run src/scripts/seed-plan.ts",
    "coach:load": "bun run src/scripts/recompute-load.ts",
    "coach:dashboard": "bun run src/scripts/render-dashboard.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "drizzle-orm": "^0.36.4",
    "next": "^15.1.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.29.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "tailwindcss": "^4.0.0-beta.7",
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "postcss": "^8.4.49",
    "typescript": "^5.7.2"
  }
}
